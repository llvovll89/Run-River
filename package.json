    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^7.0.3",
    "postcss": "^8",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.4",
    "typescript": "^5"
  }
